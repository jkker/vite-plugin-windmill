{
  "name": "vite-plugin-windmill",
  "version": "1.696.0",
  "description": "Vite plugin and deploy tooling for Windmill raw apps.",
  "keywords": [
    "raw-app",
    "spa",
    "vite",
    "vite-plugin",
    "windmill"
  ],
  "homepage": "https://github.com/jkker/vite-plugin-windmill#readme",
  "bugs": {
    "url": "https://github.com/jkker/vite-plugin-windmill/issues"
  },
  "license": "MIT",
  "author": "Jerry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkker/vite-plugin-windmill.git"
  },
  "bin": {
    "vite-plugin-windmill": "bin/vite-plugin-windmill"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack && node ./scripts/normalize-package-manifest.mjs",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "release:check": "node ./scripts/check-release.mjs",
    "release:prepare": "node ./scripts/prepare-release.mjs",
    "sync:upstream-runtime": "node ./scripts/sync-upstream-runtime.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "windmill-client": "^1.696.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260401.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vite-plus": "^0.1.18"
  },
  "peerDependencies": {
    "vite": "^8.0.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
